# ====================================================================
# Пример переменных окружения для Школы Ланы Князевой.
# Скопируйте этот файл в .env.local (локально) или задайте переменные
# через панель управления (на Timeweb Cloud / Vercel / Render / etc.).
# ====================================================================

# SQLite database — относительный путь.
# БД создаётся автоматически при первом запуске.
DATABASE_URL="file:./db/custom.db"

# Telegram bot для уведомлений о новых записях (опционально).
# Получите токен у @BotFather в Telegram.
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN="ваш_токен_от_BotFather"

# Chat ID получателя уведомлений.
# Узнать свой chat_id можно через @userinfobot (после /start вашему боту).
NEXT_PUBLIC_TELEGRAM_CHAT_ID="ваш_chat_id"

# Порт приложения (обычно задаётся платформой автоматически).
# PORT=3000
